{
  "5824824926970736106": {
    "build": {
      "command": "vite build",
      "options": {
        "cwd": "apps/frontend"
      },
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production",
        {
          "externalDependencies": [
            "vite"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/dist/apps/frontend"
      ]
    },
    "serve": {
      "command": "vite serve",
      "options": {
        "cwd": "apps/frontend"
      }
    },
    "preview": {
      "command": "vite preview",
      "options": {
        "cwd": "apps/frontend"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "build"
      }
    },
    "test": {
      "command": "vitest run",
      "options": {
        "cwd": "apps/frontend"
      },
      "cache": true,
      "inputs": [
        "default",
        "^production",
        {
          "externalDependencies": [
            "vitest"
          ]
        }
      ],
      "outputs": [
        "{workspaceRoot}/coverage/apps/frontend"
      ]
    }
  },
